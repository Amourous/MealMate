@startuml
skinparam componentStyle uml2
skinparam BackgroundColor #ffffff
skinparam component {
    BackgroundColor #ffffff
    BorderColor #2563eb
    ArrowColor #2563eb
}
skinparam database {
    BackgroundColor #ffffff
    BorderColor #16a34a
}
skinparam package {
    BackgroundColor #f9fafb
    BorderColor #d1d5db
    BorderStyle dashed
}

package "🖥️ Client Tier" as Client {
    [«component»\n<b>MealMate SPA</b>] as SPA
}

package "⚙️ Application Tier (Node.js/Express)" as App {
    [«component»\n<b>API Gateway</b>] as Gateway
    [«component»\n<b>Authentication Service</b>] as AuthService
    [«component»\n<b>Recipe Management</b>] as RecipeService
    [«component»\n<b>Meal Planning</b>] as MealPlanService
    [«component»\n<b>Pantry Management</b>] as PantryService
    
    Gateway --> AuthService
    Gateway --> RecipeService
    Gateway --> MealPlanService
    Gateway --> PantryService
}

package "💾 Data Tier" as Data {
    database "«database»\n<b>SQLite</b>" as DB
}

SPA <--> "REST API (JSON & JWT)" Gateway

AuthService ..> DB
RecipeService ..> DB
MealPlanService ..> DB
PantryService ..> DB

@enduml
